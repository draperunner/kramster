{
  "name": "kramster",
  "version": "3.0.0",
  "description": "Kramster is a quiz app for making exam preparation more fun",
  "license": "Apache-2.0",
  "author": "Mats Byrkjeland",
  "repository": {
    "type": "git",
    "url": "git://github.com/draperunner/Kramster.git"
  },
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "lint": "oxlint .",
    "stylelint": "stylelint \"src/**/*.css\"",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "test": "npm run lint && npm run stylelint && npm run format:check"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0"
  }
}
